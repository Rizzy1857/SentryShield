{
  "Service": {
    "Name": "SentryShield",
    "DisplayName": "SentryShield Security Agent",
    "Description": "Manufacturing security monitoring with supplier validation"
  },
  "Scanning": {
    "VulnerabilityScanIntervalHours": 24,
    "GatewayScanIntervalMinutes": 60,
    "DriverAuditIntervalHours": 24,
    "HardeningCheckIntervalHours": 24
  },
  "Database": {
    "Path": "C:\\ProgramData\\SentryShield\\vulnerability.db",
    "BackupPath": "C:\\ProgramData\\SentryShield\\backups\\",
    "MaxDbSizeMB": 500
  },
  "Paths": {
    "GatewayDownloadFolder": "C:\\SentryShield\\Downloads\\",
    "YaraRulesPath": "rules\\",
    "LogPath": "C:\\ProgramData\\SentryShield\\logs\\",
    "PythonExe": "python",
    "PythonScriptsPath": "scripts\\"
  },
  "Supplier": {
    "EnableGatewayValidation": true,
    "RequireSignature": true,
    "BlockOnMalwareDetection": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "EventLog": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  }
}
