<Page x:Class="SentryShield.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="{StaticResource BrushBgDeep}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="800">
            <StackPanel.Resources>
                <Style TargetType="{x:Type FrameworkElement}">
                    <Setter Property="Margin" Value="0,0,0,16"/>
                </Style>
            </StackPanel.Resources>

            <!-- ─── Scan Schedule ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type FrameworkElement}">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="SCAN SCHEDULE"
                               Style="{StaticResource H2}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Vulnerability Scan Interval"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  Width="180" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Every 6 hours"/>
                            <ComboBoxItem Content="Every 12 hours"/>
                            <ComboBoxItem Content="Daily (24h)" IsSelected="True"/>
                            <ComboBoxItem Content="Weekly"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Driver Audit Interval"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  Width="180" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Daily (24h)" IsSelected="True"/>
                            <ComboBoxItem Content="Weekly"/>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Hardening Check Interval"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  Width="180" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Daily (24h)" IsSelected="True"/>
                            <ComboBoxItem Content="Weekly"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── Gateway Settings ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type FrameworkElement}">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="GATEWAY VALIDATION"
                               Style="{StaticResource H2}"/>

                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="{x:Type FrameworkElement}">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </StackPanel.Resources>
                        <CheckBox IsChecked="True"
                                  Foreground="{StaticResource BrushTextPrimary}">
                            Enable gateway file validation
                        </CheckBox>
                        <CheckBox IsChecked="True"
                                  Foreground="{StaticResource BrushTextPrimary}">
                            Block files with malware detections
                        </CheckBox>
                        <CheckBox IsChecked="True"
                                  Foreground="{StaticResource BrushTextPrimary}">
                            Require supplier to be in trusted list
                        </CheckBox>
                    </StackPanel>

                    <Separator Style="{StaticResource SectionSeparator}"/>

                    <TextBlock Text="Trusted Suppliers"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextSecondary}"/>
                    <TextBlock Foreground="{StaticResource BrushTextMuted}"
                               FontSize="11">
                        Add supplier names that are permitted to drop files in the gateway folder.
                    </TextBlock>

                    <Border Background="{StaticResource BrushBgDeep}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12" MinHeight="80">
                        <TextBlock Text="No trusted suppliers configured. Edit C:\ProgramData\SentryShield\trusted_suppliers.json"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="11" TextWrapping="Wrap"
                                   FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─── Database ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type FrameworkElement}">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="DATABASE"
                               Style="{StaticResource H2}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Database Path"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="C:\ProgramData\SentryShield\vulnerability.db"
                                 Background="{StaticResource BrushBgDeep}"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="8,4" IsReadOnly="True"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Last Vulnerability Sync"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding LastScanText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   Padding="8,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="NVD API Key"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding NvdApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BrushBgDeep}"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="8,4" Margin="0,8,0,0"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="{x:Type FrameworkElement}">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </StackPanel.Resources>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Sync CVE Database Now"
                                Command="{Binding SyncDatabaseCommand}"
                                FontSize="12" Padding="12,6"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Open DB Folder"
                                Command="{Binding OpenDbFolderCommand}"
                                FontSize="12" Padding="12,6"/>
                    </StackPanel>

                    <!-- Live CLI Sync Log Output -->
                    <Border Background="#1E1E1E" CornerRadius="4" Margin="0,16,0,0" Padding="8">
                        <TextBox Text="{Binding SyncLogText, Mode=OneWay}" 
                                 IsReadOnly="True" 
                                 Background="Transparent" 
                                 Foreground="#00FF00" 
                                 BorderThickness="0" 
                                 FontFamily="Consolas" 
                                 FontSize="11" 
                                 Height="150" 
                                 VerticalScrollBarVisibility="Auto" 
                                 TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─── About ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type FrameworkElement}">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="ABOUT"
                               Style="{StaticResource H2}"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,4">
                        <Run Text="SentryShield v1.2-stable" FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Text="— Manufacturing Security Console"/>
                    </TextBlock>
                    <TextBlock Text="Offline-first security monitoring for ICS/OT environments."
                               Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBlock Text="Target: Windows 10/11 | .NET 8 | SQLite 3"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
