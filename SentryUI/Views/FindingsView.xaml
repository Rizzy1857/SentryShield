<Page x:Class="SentryShield.UI.Views.FindingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:SentryShield.UI.ViewModels"
      xmlns:conv="clr-namespace:SentryShield.UI.Converters"
      Title="Findings"
      Background="{StaticResource BrushBgDeep}">

    <Page.Resources>
        <!-- Cell text styles -->
        <Style x:Key="CellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="CellStyleMuted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>
    <Grid Margin="4,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── Filter bar ─── -->
        <Border Grid.Row="0"
                Padding="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ACTIVE FINDINGS"
                           Style="{StaticResource H2}"
                           VerticalAlignment="Center"/>

                <!-- Severity filter -->
                <ComboBox Grid.Column="1"
                          Width="120"
                          Margin="0,0,8,0"
                          Background="{StaticResource BrushBgCard}"
                          Foreground="{StaticResource BrushTextPrimary}"
                          BorderBrush="{StaticResource BrushBorder}"
                          SelectedItem="{Binding SeverityFilter, Mode=TwoWay}">
                    <ComboBoxItem Content="All Severities"/>
                    <ComboBoxItem Content="CRITICAL"/>
                    <ComboBoxItem Content="HIGH"/>
                    <ComboBoxItem Content="MEDIUM"/>
                    <ComboBoxItem Content="LOW"/>
                </ComboBox>

                <!-- Type filter -->
                <ComboBox Grid.Column="2"
                          Width="130"
                          Background="{StaticResource BrushBgCard}"
                          Foreground="{StaticResource BrushTextPrimary}"
                          BorderBrush="{StaticResource BrushBorder}">
                    <ComboBoxItem Content="All Types"/>
                    <ComboBoxItem Content="vulnerability"/>
                    <ComboBoxItem Content="driver"/>
                    <ComboBoxItem Content="usb_threat"/>
                    <ComboBoxItem Content="hardening"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ─── Findings DataGrid ─── -->
        <DataGrid Grid.Row="1"
                  x:Name="FindingsGrid"
                  Style="{StaticResource DarkDataGrid}"
                  ItemsSource="{Binding Findings}"
                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource DarkDataGridRow}">
                    <Setter Property="DetailsVisibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReviewing}" Value="True">
                            <Setter Property="DetailsVisibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- SEVERITY column with colored badge -->
                <DataGridTemplateColumn Header="SEVERITY" Width="100" SortMemberPath="Severity">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SeverityBadge}"
                                    Margin="8,4">
                                <Border.Background>
                                    <Binding Path="Severity" Converter="{x:Static conv:SeverityToBrushConverter.Instance}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding Severity}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="White"
                                           Padding="4,2"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- TYPE -->
                <DataGridTextColumn Header="TYPE" Width="110"
                                    Binding="{Binding FindingType}"
                                    ElementStyle="{StaticResource CellStyle}"/>

                <!-- TITLE -->
                <DataGridTextColumn Header="FINDING" Width="*"
                                    Binding="{Binding Title}"
                                    ElementStyle="{StaticResource MonospaceText}"/>

                <!-- COMPONENT -->
                <DataGridTextColumn Header="COMPONENT" Width="200"
                                    Binding="{Binding AffectedComponent}"
                                    ElementStyle="{StaticResource MonospaceText}"/>

                <!-- TIMESTAMP -->
                <DataGridTextColumn Header="DETECTED" Width="130"
                                    Binding="{Binding DetectionTimestamp, StringFormat='{}{0:MM/dd HH:mm}'}"
                                    ElementStyle="{StaticResource CellStyleMuted}"/>

                <!-- ACKNOWLEDGE button -->
                <DataGridTemplateColumn Header="" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button ClickMode="Press"
                                    Focusable="False"
                                    FontSize="11"
                                    Padding="8,3"
                                    Margin="4"
                                    Command="{Binding DataContext.AcknowledgeCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Content" Value="Acknowledge"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReviewing}" Value="True">
                                                <Setter Property="Content" Value="Confirm"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

            <!-- Row details panel — expanded view -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource BrushBgHover}"
                            Padding="16,12" Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel.Resources>
                                    <Style TargetType="{x:Type FrameworkElement}">
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                    </Style>
                                </StackPanel.Resources>
                                <TextBlock Text="DESCRIPTION"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding Description}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <StackPanel.Resources>
                                    <Style TargetType="{x:Type FrameworkElement}">
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                    </Style>
                                </StackPanel.Resources>
                                <TextBlock Text="REMEDIATION"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding Remediation}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushAccentTeal}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>

        </DataGrid>

        <!-- ─── Footer: finding count ─── -->
        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   FontSize="11"
                   Foreground="{StaticResource BrushTextMuted}">
            <Run Text="{Binding Findings.Count, Mode=OneWay}"/>
            <Run Text=" findings displayed"/>
        </TextBlock>

    </Grid>
</Page>
