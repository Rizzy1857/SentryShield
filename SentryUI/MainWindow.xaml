<Window x:Class="SentryShield.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SentryShield.UI.ViewModels"
        Title="SentryShield v1.2-stable — Manufacturing Security Console"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="1000"
        Style="{StaticResource DarkWindow}"
        WindowStartupLocation="CenterScreen">

    <!-- ViewModel as DataContext -->
    <Window.DataContext>
        <vm:DashboardViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>    <!-- Header bar -->
            <RowDefinition Height="Auto"/>  <!-- Summary tiles -->
            <RowDefinition Height="*"/>     <!-- Main content tabs -->
            <RowDefinition Height="32"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ROW 0: HEADER BAR
        ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#111820"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SENTRYSHIELD" 
                                   Foreground="{StaticResource BrushTextPrimary}" 
                                   FontWeight="SemiBold" FontSize="18"/>
                        <TextBlock Text="Manufacturing Security v1.2-stable" 
                                   Foreground="{StaticResource BrushTextSecondary}" 
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- System status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                 Margin="0,0,6,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding MachineName}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 1: SUMMARY TILES
        ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#0D1117"
                Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <StackPanel.Resources>
                    <Style TargetType="{x:Type FrameworkElement}">
                        <Setter Property="Margin" Value="0,0,12,0"/>
                    </Style>
                </StackPanel.Resources>

                <!-- CRITICAL tile -->
                <Border Style="{StaticResource SummaryTile}"
                        BorderBrush="#5A1A1A">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileCount}"
                                   Text="{Binding CriticalCount}"
                                   Foreground="{StaticResource BrushCritical}"/>
                        <TextBlock Style="{StaticResource TileLabel}" Text="CRITICAL"/>
                    </StackPanel>
                </Border>

                <!-- HIGH tile -->
                <Border Style="{StaticResource SummaryTile}"
                        BorderBrush="#5A3300">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileCount}"
                                   Text="{Binding HighCount}"
                                   Foreground="{StaticResource BrushHigh}"/>
                        <TextBlock Style="{StaticResource TileLabel}" Text="HIGH"/>
                    </StackPanel>
                </Border>

                <!-- MEDIUM tile -->
                <Border Style="{StaticResource SummaryTile}"
                        BorderBrush="#3D3000">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileCount}"
                                   Text="{Binding MediumCount}"
                                   Foreground="{StaticResource BrushMedium}"/>
                        <TextBlock Style="{StaticResource TileLabel}" Text="MEDIUM"/>
                    </StackPanel>
                </Border>

                <!-- LOW tile -->
                <Border Style="{StaticResource SummaryTile}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileCount}"
                                   Text="{Binding LowCount}"
                                   Foreground="{StaticResource BrushLow}"/>
                        <TextBlock Style="{StaticResource TileLabel}" Text="LOW"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Separator Width="1" Background="{StaticResource BrushBorder}"
                           Margin="8,0"/>

                <!-- DB Stats tile -->
                <Border Style="{StaticResource SummaryTile}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileCount}"
                                   Text="{Binding VulnDbCount}"
                                   Foreground="{StaticResource BrushAccentBlue}"/>
                        <TextBlock Style="{StaticResource TileLabel}" Text="CVEs IN DB"/>
                    </StackPanel>
                </Border>

                <!-- Spacer -->
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <TextBlock Text="{Binding LastScanText}"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding NextScanText}"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextMuted}"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 2: TABBED MAIN CONTENT
        ═══════════════════════════════════════════════════ -->
        <TabControl Grid.Row="2"
                    Margin="16,8,16,8"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="6"
                                        Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#1C2A3A"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="#161B22"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: FINDINGS -->
            <TabItem Header="📋  Findings">
                <Frame Source="Views/FindingsView.xaml" NavigationUIVisibility="Hidden"/>
            </TabItem>

            <!-- TAB 2: GATEWAY -->
            <TabItem Header="🚪  Gateway">
                <Frame Source="Views/GatewayView.xaml" NavigationUIVisibility="Hidden"/>
            </TabItem>

            <!-- TAB 3: SETTINGS -->
            <TabItem Header="⚙  Settings">
                <Frame Source="Views/SettingsView.xaml" NavigationUIVisibility="Hidden"/>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════════════════════════════════
             ROW 3: STATUS BAR + ACTION BUTTONS
        ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#111820"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"/>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Export JSON"
                            Command="{Binding ExportJsonCommand}"
                            Padding="12,4" FontSize="11" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="▶  Run Scan Now"
                            Command="{Binding RunScanCommand}"
                            IsEnabled="{Binding IsNotScanning}"
                            Padding="14,4" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
