<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         SENTRYSHIELD DESIGN SYSTEM
         Dark industrial theme — manufacturing grade
    ═══════════════════════════════════════════════════════ -->

    <!-- COLOR PALETTE -->
    <Color x:Key="BgDeep">#0D1117</Color>
    <Color x:Key="BgCard">#161B22</Color>
    <Color x:Key="BgHover">#1C2128</Color>
    <Color x:Key="BorderColor">#30363D</Color>
    <Color x:Key="TextPrimary">#E6EDF3</Color>
    <Color x:Key="TextSecondary">#8B949E</Color>
    <Color x:Key="TextMuted">#484F58</Color>
    <Color x:Key="AccentBlue">#58A6FF</Color>
    <Color x:Key="AccentTeal">#3FB950</Color>

    <!-- SEVERITY COLORS -->
    <Color x:Key="Critical">#FF4C4C</Color>
    <Color x:Key="High">#FF8C00</Color>
    <Color x:Key="Medium">#E3B341</Color>
    <Color x:Key="Low">#58A6FF</Color>
    <Color x:Key="Safe">#3FB950</Color>

    <!-- BRUSHES -->
    <SolidColorBrush x:Key="BrushBgDeep" Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BrushBgHover" Color="{StaticResource BgHover}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrushAccentBlue" Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="BrushAccentTeal" Color="{StaticResource AccentTeal}"/>
    <SolidColorBrush x:Key="BrushCritical" Color="{StaticResource Critical}"/>
    <SolidColorBrush x:Key="BrushHigh" Color="{StaticResource High}"/>
    <SolidColorBrush x:Key="BrushMedium" Color="{StaticResource Medium}"/>
    <SolidColorBrush x:Key="BrushLow" Color="{StaticResource Low}"/>
    <SolidColorBrush x:Key="BrushSafe" Color="{StaticResource Safe}"/>

    <!-- WINDOW STYLE -->
    <Style x:Key="DarkWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BrushBgDeep}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- CARD PANEL -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- SEVERITY BADGE STYLE -->
    <Style x:Key="SeverityBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- HEADING STYLES -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>

        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- SUMMARY TILE (CRITICAL / HIGH / MEDIUM / LOW counts) -->
    <Style x:Key="SummaryTile" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="MinWidth" Value="120"/>
    </Style>

    <!-- TILE COUNT TEXT -->
    <Style x:Key="TileCount" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="TileLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>

        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- PRIMARY BUTTON -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushAccentBlue}"/>
        <Setter Property="Foreground" Value="#0D1117"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#79C0FF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#3888D4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SECONDARY / OUTLINE BUTTON -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAccentBlue}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccentBlue}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1C2A3A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DARK DATA GRID -->
    <Style x:Key="DarkDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="AlternatingRowBackground" Value="#0D1117"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserSortColumns" Value="True"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
    </Style>

    <!-- DATA GRID COLUMN HEADER -->
    <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource BrushBgDeep}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
    </Style>

    <!-- DATA GRID ROW -->
    <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1C2A3A"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushBgHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- SCROLLBAR (minimal) -->
    <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- STATUS INDICATOR DOT -->
    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- SECTION SEPARATOR -->
    <Style x:Key="SectionSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BrushBorder}"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Height" Value="1"/>
    </Style>

</ResourceDictionary>
