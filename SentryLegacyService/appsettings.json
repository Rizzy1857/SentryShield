{
  "SentryShield": {
    "Scanning": {
      "VulnerabilityScanIntervalHours": 24,
      "DriverAuditIntervalHours": 24,
      "HardeningCheckIntervalHours": 6
    },
    "Paths": {
      "DatabasePath": "C:\\ProgramData\\SentryShield\\sentry.db",
      "GatewayDownloadFolder": "C:\\SentryShield\\Downloads\\",
      "YaraRulesPath": "rules\\",
      "LogPath": "C:\\ProgramData\\SentryShield\\logs\\",
      "PythonExe": "python",
      "PythonScriptsPath": "scripts\\"
    },
    "Supplier": {
      "EnableGatewayValidation": true,
      "TrustedSuppliersPath": "C:\\ProgramData\\SentryShield\\trusted_suppliers.json"
    },
    "Yara": {
      // Set to false if Python is not available on this machine.
      // SentrySetup.ps1 will auto-detect Python and configure this.
      // If true but Python is missing at runtime, the service degrades
      // gracefully: YARA scans are skipped, IOC hash + entropy still run.
      "EnableYaraScanning": true,
      "PythonExe": "python",
      "YaraScriptPath": "C:\\ProgramData\\SentryShield\\yara_scanner.py",
      "YaraRulesPath": "C:\\ProgramData\\SentryShield\\rules"
    },
    "EventLog": {
      "Source": "SentryShield",
      "Log": "Application"
    }
  }
}
